# program test(input,output);
# const PI = 3;
# var x, y : integer; z : real;
# begin
#   x := 10;
#   y := x + 5
# end.
PROGRAM program 1 1
ID test 1 9
LPAREN ( 1 13
ID input 1 14
COMMA , 1 19
ID output 1 21
RPAREN ) 1 27
SEMICOLON ; 1 28
CONST const 2 1
ID PI 2 7
EQ = 2 10
NUM 3 2 12
SEMICOLON ; 2 13
VAR var 3 1
ID x 3 5
COMMA , 3 6
ID y 3 8
COLON : 3 10
INTEGER integer 3 12
SEMICOLON ; 3 19
ID z 3 21
COLON : 3 23
REAL real 3 25
SEMICOLON ; 3 29
BEGIN begin 4 1
ID x 5 3
ASSIGN := 5 5
NUM 10 5 8
SEMICOLON ; 5 10
ID y 6 3
ASSIGN := 6 5
ID x 6 8
PLUS + 6 10
NUM 5 6 12
END end 7 1
DOT . 7 4
EOF EOF 8 1
